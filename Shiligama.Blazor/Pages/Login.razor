@page "/"
@page "/login"
@layout MainLayout
@inject AuthService Auth
@inject NavigationManager Nav

@*  Pantalla de Login — RF015 + RNF004 (control de acceso por roles).      *@

@code {
    private record RolOpt(RolUsuario R, string Icon, string L, string Hint);
    private readonly RolOpt[] _roles = new[]
    {
        new RolOpt(RolUsuario.Administrador, "📊", "Administrador", "Gestión y reportes"),
        new RolOpt(RolUsuario.Trabajador,    "🖥️", "Cajero",        "Punto de venta POS"),
        new RolOpt(RolUsuario.Cliente,       "🛍️", "Cliente",       "Tienda en línea"),
    };

    private RolUsuario? _rol;
    private string _user = "";
    private string _pass = "";
    private string _err  = "";
    private bool _loading;

    private async Task Ingresar()
    {
        if (_rol is null) return;
        _loading = true; _err = "";

        var ok = await Auth.IniciarSesionAsync(_user, _pass, _rol.Value);
        _loading = false;

        if (!ok) { _err = "Usuario o contraseña incorrectos"; return; }

        var destino = _rol switch
        {
            RolUsuario.Administrador => "/admin",
            RolUsuario.Trabajador    => "/pos",
            _                        => "/tienda",
        };
        Nav.NavigateTo(destino);
    }
}

<div style="height:100vh; display:flex; overflow:hidden;">

    <!-- ───── PANEL VISUAL (izquierda) ───── -->
    <div style="flex:1 1 60%; position:relative; display:flex; flex-direction:column;
                align-items:center; justify-content:center; padding:0 40px;
                background:radial-gradient(ellipse at 42% 50%, #1a2e48, var(--color-navy) 65%);">

        <div class="fade-up" style="text-align:center;">
            <div style="width:100px; height:100px; border-radius:50%; background:var(--color-red);
                        display:flex; align-items:center; justify-content:center;
                        font-family:var(--font-heading); font-weight:900; color:#fff; font-size:38px;
                        margin:0 auto 20px; box-shadow:0 0 0 8px rgba(224,51,34,.15), 0 6px 30px rgba(224,51,34,.5);">
                SG
            </div>
            <div style="font-family:var(--font-heading); font-weight:900; font-size:64px; line-height:.95;
                        letter-spacing:-1px; text-transform:uppercase;">Shiligama's</div>
            <div style="font-family:var(--font-heading); font-weight:700; font-size:28px;
                        color:var(--color-amber); letter-spacing:6px; text-transform:uppercase; margin-bottom:14px;">Minimarket</div>
            <div style="width:60px; height:3px; background:var(--color-amber); margin:0 auto 16px; border-radius:2px;"></div>
            <div class="muted" style="font-size:14px; letter-spacing:2px; text-transform:uppercase;">¡Donde comprar es un placer!</div>
        </div>

        <div style="position:absolute; bottom:0; left:0; right:0; padding:12px 28px;
                    background:rgba(13,27,42,.85); border-top:1px solid var(--color-border);
                    display:flex; justify-content:space-between; align-items:center;">
            <span class="muted" style="font-size:11px;">Sistema Web · .NET 10 + Blazor · Java 25 REST · Team Script E04</span>
            <span class="muted" style="font-size:11px;">PUCP Programación 3 · 2026</span>
        </div>
    </div>

    <!-- ───── FORM (derecha) ───── -->
    <div style="width:380px; background:var(--color-navy2); border-left:1px solid var(--color-border);
                display:flex; flex-direction:column; justify-content:center; padding:40px 32px;">

        <div class="fade-up" style="margin-bottom:24px;">
            <div style="font-family:var(--font-heading); font-weight:800; font-size:28px;">Iniciar Sesión</div>
            <div class="muted" style="font-size:13px; margin-top:4px;">Selecciona tu rol y accede al sistema</div>
        </div>

        <!-- Selector de rol -->
        <div style="margin-bottom:20px;">
            <div class="muted" style="font-size:11px; font-weight:600; letter-spacing:.5px;
                                      text-transform:uppercase; margin-bottom:8px;">Tu rol</div>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px;">
                @foreach (var r in _roles)
                {
                    var selected = _rol == r.R;
                    <button class="btn" @onclick="() => { _rol = r.R; _user = r.R.ToString().ToLower(); _err = ""; }"
                            style="background:@(selected ? "rgba(245,161,0,.12)" : "var(--color-card)");
                                   border:2px solid @(selected ? "var(--color-amber)" : "var(--color-border)");
                                   border-radius:12px; padding:10px 6px; text-align:center;">
                        <div style="font-size:22px; margin-bottom:4px;">@r.Icon</div>
                        <div style="font-family:var(--font-heading); font-weight:700; font-size:12px;
                                    color:@(selected ? "var(--color-amber)" : "var(--color-offwhite)");">@r.L</div>
                    </button>
                }
            </div>
        </div>

        @if (_rol is not null)
        {
            <EditForm Model="this" OnValidSubmit="Ingresar">
                <div style="margin-bottom:10px;">
                    <div class="muted" style="font-size:11px; font-weight:600; letter-spacing:.5px; text-transform:uppercase; margin-bottom:5px;">Usuario</div>
                    <input class="inp" @bind="_user" autocomplete="username" />
                </div>
                <div style="margin-bottom:12px;">
                    <div class="muted" style="font-size:11px; font-weight:600; letter-spacing:.5px; text-transform:uppercase; margin-bottom:5px;">Contraseña</div>
                    <input class="inp" type="password" @bind="_pass" />
                </div>

                @if (!string.IsNullOrEmpty(_err))
                {
                    <div style="font-size:12px; color:var(--color-red);
                                background:rgba(224,51,34,.1); border:1px solid rgba(224,51,34,.2);
                                padding:8px 12px; border-radius:8px; margin-bottom:10px;">@_err</div>
                }

                <button type="submit" class="btn btn-primary pulse"
                        disabled="@_loading"
                        style="width:100%; padding:14px 0; font-size:17px;">
                    @(_loading ? "Verificando..." : "Ingresar al Sistema →")
                </button>
                <div class="muted" style="font-size:11px; text-align:center; margin-top:8px;">
                    Demo: usuario = <b style="color:var(--color-offwhite);">@_user</b> · contraseña = <b style="color:var(--color-offwhite);">1234</b>
                </div>
            </EditForm>
        }
        else
        {
            <div class="muted" style="text-align:center; font-size:13px; padding:20px 0;">👆 Selecciona un rol para continuar</div>
        }
    </div>
</div>
