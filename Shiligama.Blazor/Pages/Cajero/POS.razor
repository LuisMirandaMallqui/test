@page "/pos"
@layout MainLayout
@inject ProductoService ProdSvc
@inject PedidoService PedidoSvc
@inject AuthService Auth

@*  Cajero POS — RF006 comprobante, RF007 métodos de pago, RF004 stock.     *@

@code {
    private List<Producto> _productos = new();
    private List<(Producto p, int qty)> _ticket = new();
    private string _cat = "Todos";
    private string _q = "";
    private bool _loading = true;
    private bool _showPay;
    private Pedido? _ticketFinal;

    private readonly string[] _cats = { "Todos","Abarrotes","Bebidas","Lácteos","Limpieza","Snacks","Frutas","Panadería" };
    private string IconCat(string c) => c switch
    {
        "Abarrotes"=>"🥫", "Bebidas"=>"🥤", "Lácteos"=>"🥛", "Limpieza"=>"🧴",
        "Snacks"=>"🍿", "Frutas"=>"🥬", "Panadería"=>"🍞", _ => "🛒",
    };

    protected override async Task OnInitializedAsync()
    {
        _productos = await ProdSvc.ListarAsync();
        _loading = false;
    }

    private IEnumerable<Producto> Filtrados =>
        _productos.Where(p =>
            (_cat == "Todos" || p.CategoriaNombre == _cat) &&
            (string.IsNullOrWhiteSpace(_q) || p.Nombre.Contains(_q, StringComparison.OrdinalIgnoreCase)));

    private void Agregar(Producto p)
    {
        var i = _ticket.FindIndex(x => x.p.Id == p.Id);
        if (i < 0) _ticket.Add((p, 1));
        else       _ticket[i] = (p, _ticket[i].qty + 1);
    }
    private void Cambiar(int id, int delta)
    {
        var i = _ticket.FindIndex(x => x.p.Id == id);
        if (i < 0) return;
        var n = _ticket[i].qty + delta;
        if (n <= 0) _ticket.RemoveAt(i);
        else        _ticket[i] = (_ticket[i].p, n);
    }
    private decimal Total => _ticket.Sum(t => t.p.Precio * t.qty);
    private decimal Igv   => Math.Round(Total * 0.18m / 1.18m, 2);

    private async Task Cobrar((MetodoPago metodo, decimal efectivo) data)
    {
        var pedido = new Pedido
        {
            Codigo    = $"POS-{DateTime.Now:HHmmss}",
            Canal     = CanalVenta.Presencial,
            MetodoPago= data.metodo,
            Subtotal  = Total - Igv,
            Igv       = Igv,
            Total     = Total,
            Estado    = EstadoPedido.Pagado,
            ClienteNombre = "Consumidor Final",
            Detalles  = _ticket.Select(t => new DetallePedido {
                ProductoId = t.p.Id, ProductoNombre = t.p.Nombre,
                Cantidad = t.qty, PrecioUnitario = t.p.Precio
            }).ToList()
        };
        _ticketFinal = await PedidoSvc.ConfirmarVentaPosAsync(pedido) ?? pedido;
        _ticket.Clear();
        _showPay = false;
    }
}

<AppHeader BadgeText="CAJERO POS" BadgeColor="amber" />

<div style="display:flex; flex:1; overflow:hidden;">

    <!-- ── Catálogo ── -->
    <div style="flex:1; display:flex; flex-direction:column; padding:12px 14px; gap:10px; overflow:hidden;">
        <input class="inp" placeholder="🔍 Buscar producto..." @bind="_q" @bind:event="oninput" />

        <div style="display:flex; gap:5px; overflow-x:auto;">
            @foreach (var c in _cats)
            {
                var sel = _cat == c;
                <button class="btn" @onclick="() => _cat = c"
                        style="background:@(sel ? "var(--color-amber)" : "var(--color-card)");
                               color:@(sel ? "var(--color-navy)" : "var(--color-muted)");
                               border:@(sel ? "none" : "1px solid var(--color-border)");
                               border-radius:7px; padding:4px 10px; font-size:12px; white-space:nowrap;">
                    @IconCat(c) @c
                </button>
            }
        </div>

        <div style="flex:1; overflow-y:auto; display:grid;
                    grid-template-columns:repeat(auto-fill, minmax(140px, 1fr)); gap:8px;">
            @if (_loading)
            {
                @for (int i = 0; i < 12; i++) { <div style="height:120px; background:var(--color-card); border-radius:12px; animation:fadeUp .4s ease both;"></div> }
            }
            else
            {
                @foreach (var p in Filtrados)
                {
                    <div class="card fade-up" style="padding:10px; cursor:pointer;"
                         @onclick="() => Agregar(p)">
                        <div style="display:flex; justify-content:space-between;">
                            <span style="font-size:22px;">@IconCat(p.CategoriaNombre)</span>
                            @if (p.Descuento > 0)
                            {
                                <span style="background:var(--color-red); color:#fff; font-size:9px;
                                              font-weight:700; padding:2px 5px; border-radius:4px;">-@(p.Descuento)%</span>
                            }
                        </div>
                        <div style="font-size:11px; font-weight:600; line-height:1.3; margin-top:4px;">@p.Nombre</div>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:4px;">
                            <span class="mono amber" style="font-weight:700; font-size:13px;">S/@p.Precio.ToString("F2")</span>
                            <span class="muted" style="font-size:9px;">/@p.Unidad</span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── Ticket ── -->
    <div style="width:320px; display:flex; flex-direction:column; background:var(--color-navy2);
                border-left:1px solid var(--color-border); overflow:hidden;">

        <div style="padding:10px 14px; border-bottom:1px solid var(--color-border);
                    display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div style="font-family:var(--font-heading); font-weight:800; font-size:16px;">🧾 TICKET</div>
                <div class="muted" style="font-size:10px;">@_ticket.Count productos</div>
            </div>
            @if (_ticket.Count > 0)
            {
                <button class="btn btn-ghost" style="font-size:11px; padding:4px 9px;" @onclick="() => _ticket.Clear()">✕ Vaciar</button>
            }
        </div>

        <div style="flex:1; overflow-y:auto; padding:8px 12px; display:flex; flex-direction:column; gap:5px;">
            @if (_ticket.Count == 0)
            {
                <div class="muted" style="text-align:center; font-size:12px; padding-top:40px;">
                    Toca un producto del catálogo<br />para agregarlo
                </div>
            }
            else
            {
                @foreach (var t in _ticket)
                {
                    <div style="display:flex; align-items:center; gap:6px;
                                background:var(--color-card); border-radius:9px; padding:7px 9px;">
                        <div style="font-size:16px;">@IconCat(t.p.CategoriaNombre)</div>
                        <div style="flex:1; min-width:0;">
                            <div style="font-size:11px; font-weight:600;">@t.p.Nombre</div>
                            <div class="mono muted" style="font-size:10px;">S/@t.p.Precio.ToString("F2") c/u</div>
                        </div>
                        <div style="display:flex; align-items:center; gap:3px;">
                            <button class="btn btn-ghost" style="width:20px; height:20px; padding:0; font-size:13px;"
                                    @onclick="() => Cambiar(t.p.Id, -1)">−</button>
                            <span class="mono" style="font-size:12px; font-weight:700; min-width:18px; text-align:center;">@t.qty</span>
                            <button class="btn btn-primary" style="width:20px; height:20px; padding:0; font-size:13px;"
                                    @onclick="() => Cambiar(t.p.Id, +1)">+</button>
                        </div>
                        <div class="mono amber" style="font-weight:700; font-size:12px; min-width:46px; text-align:right;">
                            S/@((t.p.Precio * t.qty).ToString("F2"))
                        </div>
                    </div>
                }
            }
        </div>

        <div style="padding:10px 14px; border-top:1px solid var(--color-border);">
            <div style="display:flex; justify-content:space-between; font-size:11px; color:var(--color-muted); margin-bottom:2px;">
                <span>Subtotal</span><span class="mono">S/@((Total - Igv).ToString("F2"))</span>
            </div>
            <div style="display:flex; justify-content:space-between; font-size:11px; color:var(--color-muted); margin-bottom:10px;">
                <span>IGV (18%)</span><span class="mono">S/@Igv.ToString("F2")</span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center;
                        padding-top:10px; border-top:1px solid var(--color-border); margin-bottom:12px;">
                <span style="font-family:var(--font-heading); font-weight:700; font-size:18px;">TOTAL</span>
                <span class="mono amber" style="font-weight:700; font-size:24px;">S/@Total.ToString("F2")</span>
            </div>
            <button class="btn btn-primary @(_ticket.Count > 0 ? "pulse" : "")"
                    style="width:100%; padding:18px 0; font-size:20px;"
                    disabled="@(_ticket.Count == 0)"
                    @onclick="() => _showPay = true">
                ⚡ COBRAR S/@Total.ToString("F2")
            </button>
        </div>
    </div>
</div>

@if (_showPay)
{
    <PaymentModal Total="Total"
                  OnConfirmar="Cobrar"
                  OnCerrar="() => _showPay = false" />
}

@if (_ticketFinal is not null)
{
    <div style="position:fixed; inset:0; background:rgba(6,12,20,.85);
                display:flex; align-items:center; justify-content:center; z-index:90;"
         @onclick="() => _ticketFinal = null">
        <div class="card fade-up" style="width:440px; padding:28px; text-align:center;"
             @onclick:stopPropagation>
            <div style="font-size:54px;">✅</div>
            <div style="font-family:var(--font-heading); font-weight:800; font-size:24px; color:var(--color-green);">¡VENTA EXITOSA!</div>
            <div class="muted" style="font-size:12px; margin:6px 0 4px;">
                Comprobante @(_ticketFinal.NumeroComprobante ?? "Nubefact pendiente") · RF006
            </div>
            <div class="muted" style="font-size:12px; margin-bottom:18px;">@_ticketFinal.MetodoPago</div>
            <div style="background:var(--color-navy3); border-radius:12px; padding:14px 18px;
                        text-align:left; margin-bottom:18px;">
                @foreach (var d in _ticketFinal.Detalles.Take(4))
                {
                    <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:4px;">
                        <span class="muted">@d.Cantidad × @d.ProductoNombre</span>
                        <span class="mono">S/@d.Subtotal.ToString("F2")</span>
                    </div>
                }
                <div style="border-top:1px solid var(--color-border); margin-top:8px; padding-top:8px;
                            display:flex; justify-content:space-between;">
                    <span style="font-family:var(--font-heading); font-weight:700;">TOTAL</span>
                    <span class="mono amber" style="font-weight:700;">S/@_ticketFinal.Total.ToString("F2")</span>
                </div>
            </div>
            <button class="btn btn-primary" style="width:100%; padding:13px 0; font-size:17px;"
                    @onclick="() => _ticketFinal = null">+ Nueva Venta</button>
        </div>
    </div>
}
