@page "/admin/proveedores"
@layout AdminLayout

@code {
    private record Sup(string Razon, string Ruc, string Cat, string Contacto, string Tel, int Lead, bool Active);
    private readonly Sup[] _sups = new[]
    {
        new Sup("Distribuidora Lima Norte SAC","20512345678","Abarrotes","Carlos Quispe","998-123-456",3,true),
        new Sup("Lácteos Gloria S.A.",        "20100190797","Lácteos",  "Ana Rodríguez","987-456-321",2,true),
        new Sup("Bebidas AJE Group",          "20331061655","Bebidas",  "Luis Mendoza", "995-741-852",1,true),
        new Sup("Snacks Karinto E.I.R.L.",    "20425369874","Snacks",   "Rosa Vega",    "963-258-147",4,true),
        new Sup("Frutas del Valle",           "20587412365","Frutas",   "José Huamán",  "974-369-852",1,false),
    };
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">🚚 Proveedores</div>
    <div style="flex:1;"></div>
    <button class="btn btn-primary" style="padding:8px 14px; font-size:12px;">+ Nuevo proveedor</button>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    <table class="tbl">
        <thead><tr><th>Proveedor</th><th>RUC</th><th>Categoría</th><th>Contacto</th><th>Teléfono</th><th>Lead</th><th>Estado</th></tr></thead>
        <tbody>
            @foreach (var s in _sups)
            {
                <tr>
                    <td style="font-weight:600;">@s.Razon</td>
                    <td class="mono muted">@s.Ruc</td>
                    <td><Pill Variant="amber">@s.Cat</Pill></td>
                    <td>@s.Contacto</td>
                    <td class="mono muted">@s.Tel</td>
                    <td class="mono">@s.Lead días</td>
                    <td>
                        @if (s.Active)
                        {
                            <Pill Variant="green">● Activo</Pill>
                        }
                        else
                        {
                            <Pill Variant="red">● Inactivo</Pill>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
