@page "/admin/reportes"
@layout AdminLayout
@inject ReporteService ReporteSvc

@*  Reportes — RF013 (ventas), RF014 (más vendidos POS vs WhatsApp).         *@

@code {
    private List<ReporteService.RankingProducto> _ranking = new();

    protected override async Task OnInitializedAsync()
    {
        _ranking = await ReporteSvc.MasVendidosAsync(DateTime.Now.AddDays(-30), DateTime.Now);
    }
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">📈 Reportes Analíticos</div>
    <Pill Variant="amber">RF013 · RF014</Pill>
    <div style="flex:1;"></div>
    <button class="btn btn-ghost">📅 Mayo 2026</button>
    <button class="btn btn-primary" style="padding:8px 14px; font-size:12px;">⬇ Exportar PDF</button>
</div>

<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:18px;">
    <StatCard Icon="💰" Label="Ingresos mes"   Value="S/8,420" Sub="+18% vs abr"     Color="var(--color-amber)"/>
    <StatCard Icon="🧾" Label="Transacciones"  Value="412"      Sub="312 POS · 100 WA" Color="var(--color-blue)"/>
    <StatCard Icon="🎯" Label="Ticket promedio" Value="S/20.4"  Sub="por venta"      Color="var(--color-green)"/>
    <StatCard Icon="📉" Label="Mermas mes"     Value="S/74.05" Sub="0.9% ingresos"   Color="var(--color-red)"/>
</div>

<div class="card" style="margin-bottom:14px;">
    <div style="display:flex; justify-content:space-between; margin-bottom:14px;">
        <div style="font-family:var(--font-heading); font-weight:700; font-size:16px;">🏆 Más vendidos · Presencial vs WhatsApp</div>
        <Pill Variant="amber">RF014</Pill>
    </div>

    @{
        var max = _ranking.Count == 0 ? 1 : _ranking.Max(r => r.Total);
    }

    @for (int i = 0; i < _ranking.Count; i++)
    {
        var r = _ranking[i];
        <div style="margin-bottom:10px;">
            <div style="display:flex; justify-content:space-between; margin-bottom:3px; font-size:12px;">
                <span><span style="font-family:var(--font-heading); font-weight:800;
                                    color:@(i<3 ? "var(--color-amber)" : "var(--color-muted)"); margin-right:8px;">#@(i+1)</span>@r.Producto</span>
                <span class="mono" style="font-weight:700;">@r.Total</span>
            </div>
            <div style="display:flex; height:8px; border-radius:4px; overflow:hidden; background:var(--color-navy3);">
                <div style="width:@((double)r.Presencial / max * 70)%; background:var(--color-amber);"></div>
                <div style="width:@((double)r.WhatsApp / max * 70)%; background:var(--color-green);"></div>
            </div>
            <div style="display:flex; justify-content:space-between; font-size:10px; margin-top:3px; font-family:var(--font-mono);">
                <span class="amber">POS: @r.Presencial</span>
                <span class="green">WA: @r.WhatsApp</span>
            </div>
        </div>
    }
</div>

<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">
    @foreach (var (ic, t, d, rf) in new[]
    {
        ("📊", "Reporte de Ventas", "Detallado por período, producto y canal", "RF013"),
        ("🏆", "Más Vendidos",      "Ranking POS vs WhatsApp delivery",        "RF014"),
        ("🔄", "Mermas",            "Análisis de pérdidas y devoluciones",     "RF012"),
    })
    {
        <div class="card" style="cursor:pointer;">
            <div style="font-size:32px; margin-bottom:8px;">@ic</div>
            <div style="font-family:var(--font-heading); font-weight:700; font-size:15px; margin-bottom:4px;">@t</div>
            <div class="muted" style="font-size:11px; line-height:1.5; margin-bottom:8px;">@d</div>
            <Pill Variant="amber">@rf</Pill>
        </div>
    }
</div>
