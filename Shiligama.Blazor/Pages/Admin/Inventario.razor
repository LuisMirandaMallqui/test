@page "/admin/inventario"
@layout AdminLayout
@inject ProductoService ProdSvc

@code {
    private List<Producto> _productos = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _productos = await ProdSvc.ListarAsync();
        _loading = false;
    }
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">📦 Inventario</div>
    <Pill Variant="amber">RF004 · RF005</Pill>
    <div style="flex:1;"></div>
    <button class="btn btn-ghost">📥 Importar</button>
    <button class="btn btn-primary" style="padding:8px 14px; font-size:12px;">+ Reabastecer</button>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    <table class="tbl">
        <thead>
            <tr>
                <th>Producto</th><th>Categoría</th><th>Precio</th>
                <th>Stock</th><th>Vendidos</th><th>Estado</th><th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (_loading)
            {
                <tr><td colspan="7" class="muted" style="text-align:center; padding:20px;">Cargando...</td></tr>
            }
            else
            {
                @foreach (var p in _productos)
                {
                    var (lbl, cls) = p.Stock < 5  ? ("🔴 Crítico", "pill-red")
                                   : p.Stock < 10 ? ("🟡 Bajo",    "pill-amber")
                                                  : ("🟢 OK",      "pill-green");
                    <tr>
                        <td style="font-weight:600;">@p.Nombre</td>
                        <td class="muted">@p.CategoriaNombre</td>
                        <td class="mono amber">S/@p.Precio.ToString("F2")</td>
                        <td>
                            <div style="display:flex; align-items:center; gap:8px;">
                                <span class="mono" style="font-weight:700; min-width:24px;
                                       color:@(p.Stock<5 ? "var(--color-red)" : p.Stock<10 ? "var(--color-amber)" : "var(--color-green)");">@p.Stock</span>
                                <div style="flex:1; max-width:80px; height:5px; background:var(--color-navy3); border-radius:3px;">
                                    <div style="height:100%; width:@(Math.Min(100, p.Stock*2.5))%;
                                                background:@(p.Stock<5 ? "var(--color-red)" : p.Stock<10 ? "var(--color-amber)" : "var(--color-green)");
                                                border-radius:3px;"></div>
                                </div>
                            </div>
                        </td>
                        <td class="mono muted">@p.Vendidos</td>
                        <td><span class="pill @cls">@lbl</span></td>
                        <td>
                            <button class="btn btn-ghost" style="color:var(--color-amber); border-color:var(--color-amber); padding:3px 8px; font-size:10px;">+ Stock</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
