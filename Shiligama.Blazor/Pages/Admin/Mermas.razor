@page "/admin/mermas"
@layout AdminLayout

@*  Devoluciones y mermas — RF011 (registro), RF012 (reporte).               *@

@code {
    private record MermaDemo(DateTime Fecha, string Prod, decimal Qty, string Motivo, decimal Monto, string User);
    private readonly List<MermaDemo> _mermas = new()
    {
        new(new(2026,5,23), "Leche Gloria Tarro",   3,   "Vencido",             11.40m, "María L."),
        new(new(2026,5,22), "Yogurt Gloria 180g",   2,   "Envase dañado",        4.40m, "Admin G."),
        new(new(2026,5,21), "Pan de Molde Bimbo",   5,   "Vencido",             22.50m, "María L."),
        new(new(2026,5,20), "Cebolla Roja (kg)",    1.5m,"Producto malogrado",   3.75m, "María L."),
        new(new(2026,5,19), "Huevo La Calera",      4,   "Rotura",              32.00m, "Admin G."),
    };
    private decimal Total => _mermas.Sum(m => m.Monto);
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">🔄 Devoluciones & Mermas</div>
    <Pill Variant="amber">RF011 · RF012</Pill>
    <div style="flex:1;"></div>
    <button class="btn btn-primary" style="padding:8px 14px; font-size:12px;">+ Registrar merma</button>
</div>

<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:18px;">
    <StatCard Icon="💸" Label="Pérdida total" Value="@($"S/{Total:F2}")" Sub="Últimos 5 días" Color="var(--color-red)"/>
    <StatCard Icon="📦" Label="Productos"     Value="@_mermas.Count.ToString()" Sub="registros" Color="var(--color-amber)"/>
    <StatCard Icon="🥇" Label="Motivo top"    Value="Vencido" Sub="40% de mermas" Color="var(--color-blue)"/>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    <table class="tbl">
        <thead><tr><th>Fecha</th><th>Producto</th><th>Cantidad</th><th>Motivo</th><th>Pérdida S/</th><th>Registrado por</th></tr></thead>
        <tbody>
            @foreach (var m in _mermas)
            {
                <tr>
                    <td class="mono muted">@m.Fecha.ToString("yyyy-MM-dd")</td>
                    <td style="font-weight:600;">@m.Prod</td>
                    <td class="mono">@m.Qty</td>
                    <td><Pill Variant="red">@m.Motivo</Pill></td>
                    <td class="mono red" style="font-weight:700;">S/@m.Monto.ToString("F2")</td>
                    <td class="muted">@m.User</td>
                </tr>
            }
        </tbody>
    </table>
</div>
