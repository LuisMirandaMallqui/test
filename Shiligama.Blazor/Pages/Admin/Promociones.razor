@page "/admin/promociones"
@layout AdminLayout

@*  Promociones y motor de cross-selling — RF009, RF010.                     *@

@code {
    private record Promo(string Name, string Tipo, string Prods, int Disc, string From, string To, bool Active);
    private readonly Promo[] _promos = new[]
    {
        new Promo("Combo Desayuno",  "Combo",     "Pan + Leche + Huevos",          15, "2026-05-20","2026-05-31",true),
        new Promo("Flash Bebidas",   "Descuento", "Inka Kola, Coca-Cola 1.5L",    30, "2026-05-25","2026-05-25",true),
        new Promo("2x1 Snacks",      "2x1",       "Chips Lay's, Galletas Ritz",   50, "2026-06-01","2026-06-07",false),
        new Promo("Limpieza -20%",   "Descuento", "Línea Limpieza",                20, "2026-05-15","2026-05-30",true),
    };

    private record Cross(string A, string B, double Score);
    private readonly Cross[] _cross = new[]
    {
        new Cross("🥛 Leche",   "🍞 Pan",      0.87),
        new Cross("🥤 Gaseosa", "🍿 Snacks",   0.74),
        new Cross("🥚 Huevos",  "🥬 Tomate",   0.65),
    };
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">🏷️ Promociones & Cross-selling</div>
    <Pill Variant="amber">RF009 · RF010</Pill>
    <div style="flex:1;"></div>
    <button class="btn btn-primary" style="padding:8px 14px; font-size:12px;">+ Nueva promoción</button>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:18px;">
    @foreach (var p in _promos)
    {
        <div class="card" style="border-color:@(p.Active ? "rgba(46,204,122,.3)" : "var(--color-border)");">
            <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                <div>
                    <div style="font-family:var(--font-heading); font-weight:700; font-size:16px;">@p.Name</div>
                    <div class="muted" style="font-size:11px; margin-top:2px;">@p.Prods</div>
                </div>
                @if (p.Active) { <Pill Variant="green">● Activa</Pill> } else { <Pill Variant="red">● Inactiva</Pill> }
            </div>
            <div style="display:flex; gap:8px; margin-bottom:8px;">
                <Pill Variant="blue">@p.Tipo</Pill>
                <Pill Variant="amber">-@p.Disc%</Pill>
            </div>
            <div class="mono muted" style="font-size:11px;">@p.From → @p.To</div>
        </div>
    }
</div>

<div class="card">
    <div style="display:flex; justify-content:space-between; margin-bottom:14px;">
        <div style="font-family:var(--font-heading); font-weight:700; font-size:16px;">🤖 Motor de Recomendaciones (Cross-selling)</div>
        <Pill Variant="amber">RF010 · BL Java</Pill>
    </div>
    <div class="muted" style="font-size:12px; margin-bottom:14px; line-height:1.6;">
        Algoritmo que sugiere productos complementarios según la categoría y los ítems del carrito.
        Implementado en la capa de Lógica de Negocio del backend Java.
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px;">
        @foreach (var r in _cross)
        {
            <div style="background:var(--color-navy3); border-radius:10px; padding:12px 14px;">
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
                    <span style="font-size:16px;">@r.A</span>
                    <span class="muted" style="font-size:14px;">→</span>
                    <span style="font-size:16px;">@r.B</span>
                </div>
                <div class="mono amber" style="font-size:11px;">confidence @r.Score</div>
            </div>
        }
    </div>
</div>
