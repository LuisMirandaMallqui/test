@page "/admin/productos"
@layout AdminLayout
@inject ProductoService ProdSvc

@code {
    private List<Producto> _productos = new();
    private readonly string[] _cats = { "Abarrotes","Bebidas","Lácteos","Limpieza","Snacks","Frutas","Panadería" };
    private string Icon(string c) => c switch {
        "Abarrotes"=>"🥫", "Bebidas"=>"🥤", "Lácteos"=>"🥛", "Limpieza"=>"🧴",
        "Snacks"=>"🍿", "Frutas"=>"🥬", "Panadería"=>"🍞", _ => "📦" };

    protected override async Task OnInitializedAsync() => _productos = await ProdSvc.ListarAsync();
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">🛒 Productos & Categorías</div>
    <Pill Variant="amber">RF002 · RF003</Pill>
    <div style="flex:1;"></div>
    <button class="btn btn-primary" style="padding:8px 14px; font-size:12px;">+ Nuevo producto</button>
</div>

<div class="muted" style="font-family:var(--font-heading); font-weight:700; font-size:14px; margin-bottom:14px;">CATEGORÍAS</div>
<div style="display:grid; grid-template-columns:repeat(7,1fr); gap:10px; margin-bottom:22px;">
    @foreach (var c in _cats)
    {
        var cnt = _productos.Count(p => p.CategoriaNombre == c);
        <div class="card" style="padding:14px 8px; text-align:center;">
            <div style="font-size:30px; margin-bottom:6px;">@Icon(c)</div>
            <div style="font-family:var(--font-heading); font-weight:700; font-size:12px;">@c</div>
            <div class="mono amber" style="font-weight:700; font-size:14px; margin-top:3px;">@cnt</div>
        </div>
    }
</div>

<div class="muted" style="font-family:var(--font-heading); font-weight:700; font-size:14px; margin-bottom:10px;">
    CATÁLOGO (@_productos.Count productos)
</div>
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:10px;">
    @foreach (var p in _productos)
    {
        <div class="card" style="padding:12px 14px; display:flex; gap:10px; align-items:center;">
            <div style="width:38px; height:38px; background:var(--color-navy3); border-radius:8px;
                        display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">
                @Icon(p.CategoriaNombre)
            </div>
            <div style="flex:1; min-width:0;">
                <div style="font-size:12px; font-weight:600;">@p.Nombre</div>
                <div class="muted" style="font-size:10px;">@p.CategoriaNombre · @p.Unidad</div>
                <div class="mono amber" style="font-size:12px; font-weight:700; margin-top:2px;">S/@p.Precio.ToString("F2")</div>
            </div>
        </div>
    }
</div>
