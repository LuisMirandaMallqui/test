@page "/admin"
@layout AdminLayout
@inject ProductoService ProdSvc
@inject ReporteService ReporteSvc

@*  Dashboard del Administrador — KPIs + integraciones.                     *@

@code {
    private List<Producto> _stockCritico = new();
    private List<ReporteService.VentaPorDia> _ventas = new();
    private decimal _ventasHoy = 342.80m;
    private int _pedidosHoy = 23;
    private int _pedidosWA  = 4;

    protected override async Task OnInitializedAsync()
    {
        _stockCritico = await ProdSvc.StockCriticoAsync();
        _ventas       = await ReporteSvc.VentasSemanaAsync();
    }
}

<div style="display:flex; align-items:center; margin-bottom:18px; gap:14px;">
    <div style="font-family:var(--font-heading); font-weight:800; font-size:22px;">📊 Dashboard Operativo</div>
</div>

<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px;">
    <StatCard Icon="💰" Label="Ventas Hoy"    Value="@($"S/{_ventasHoy:F2}")" Sub="+12% vs ayer"            Color="var(--color-amber)" />
    <StatCard Icon="🧾" Label="Tickets"       Value="@_pedidosHoy.ToString()" Sub="14 presencial · 9 WA"    Color="var(--color-blue)"  />
    <StatCard Icon="💬" Label="Pedidos WA"    Value="@_pedidosWA.ToString()"  Sub="por procesar"            Color="var(--color-green)" />
    <StatCard Icon="⚠️" Label="Stock Crítico" Value="@_stockCritico.Count.ToString()" Sub="bajo mínimo (RF005)" Color="var(--color-red)" />
</div>

<div style="display:grid; grid-template-columns:1.4fr 1fr; gap:14px; margin-bottom:14px;">

    <!-- Ventas semana -->
    <div class="card">
        <div style="display:flex; justify-content:space-between; margin-bottom:14px;">
            <div style="font-family:var(--font-heading); font-weight:700; font-size:16px;">📈 Ventas esta semana</div>
            <Pill Variant="amber">RF013</Pill>
        </div>
        <div style="display:flex; align-items:flex-end; gap:8px; height:120px;">
            @{
                var max = _ventas.Count > 0 ? (double)_ventas.Max(v => v.Total) : 1;
            }
            @foreach (var v in _ventas)
            {
                <div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:4px;">
                    <div class="mono amber" style="font-size:10px;">S/@v.Total.ToString("F0")</div>
                    <div style="width:100%; background:linear-gradient(180deg, var(--color-amber), var(--color-amber2));
                                border-radius:4px 4px 0 0; height:@((int)((double)v.Total / max * 92))px;"></div>
                    <div class="muted" style="font-size:10px;">@v.Dia</div>
                </div>
            }
        </div>
    </div>

    <!-- Canal de venta -->
    <div class="card">
        <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
            <div style="font-family:var(--font-heading); font-weight:700; font-size:16px;">🥧 Canal de venta</div>
            <Pill Variant="blue">RF014</Pill>
        </div>
        <div style="display:flex; align-items:center; gap:18px;">
            <svg viewBox="0 0 42 42" width="120" height="120">
                <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="var(--color-navy3)" stroke-width="6" />
                <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="var(--color-amber)" stroke-width="6" stroke-dasharray="62 38" stroke-dashoffset="25" />
                <circle cx="21" cy="21" r="15.9" fill="transparent" stroke="var(--color-green)" stroke-width="6" stroke-dasharray="38 62" stroke-dashoffset="-37" />
            </svg>
            <div style="display:flex; flex-direction:column; gap:10px;">
                <div>
                    <div class="muted" style="font-size:11px;">
                        <span style="display:inline-block; width:8px; height:8px; background:var(--color-amber); border-radius:2px; margin-right:6px;"></span>
                        Presencial POS
                    </div>
                    <div class="mono amber" style="font-weight:700; font-size:18px;">62% · S/213</div>
                </div>
                <div>
                    <div class="muted" style="font-size:11px;">
                        <span style="display:inline-block; width:8px; height:8px; background:var(--color-green); border-radius:2px; margin-right:6px;"></span>
                        WhatsApp
                    </div>
                    <div class="mono green" style="font-weight:700; font-size:18px;">38% · S/130</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">

    <!-- Stock crítico -->
    <div class="card" style="border-color:rgba(224,51,34,.25);">
        <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
            <div style="font-family:var(--font-heading); font-weight:700; font-size:15px; color:var(--color-red);">⚠️ Alertas de Stock</div>
            <Pill Variant="red">RF005</Pill>
        </div>
        @foreach (var p in _stockCritico)
        {
            <div style="display:flex; justify-content:space-between; align-items:center;
                        padding:6px 0; border-bottom:1px solid var(--color-border);">
                <span style="font-size:12px;">@p.Nombre</span>
                <div style="display:flex; gap:8px; align-items:center;">
                    <Pill Variant="red">@p.Stock u.</Pill>
                    <button class="btn btn-ghost" style="font-size:10px; padding:2px 8px; color:var(--color-amber); border-color:var(--color-amber);">Pedir</button>
                </div>
            </div>
        }
    </div>

    <!-- Integraciones -->
    <div class="card">
        <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
            <div style="font-family:var(--font-heading); font-weight:700; font-size:15px;">🔌 Integraciones</div>
            <Pill Variant="blue">RNF010</Pill>
        </div>
        @foreach (var (ic, n, s, c) in new[]
        {
            ("💬","WhatsApp Bot (n8n)",    "Activo · 142 conv.", "var(--color-green)"),
            ("🧾","Nubefact SUNAT",         "Modo pruebas",       "var(--color-amber)"),
            ("💳","Mercado Pago",           "Sandbox · OK",       "var(--color-amber)"),
            ("🏢","POS Microsoft (legacy)", "Lectura BD",         "var(--color-muted)"),
        })
        {
            <div style="display:flex; justify-content:space-between; align-items:center;
                        padding:7px 0; border-bottom:1px solid var(--color-border);">
                <span style="font-size:12px;"><span style="margin-right:8px;">@ic</span>@n</span>
                <span style="font-size:11px; color:@c; font-family:var(--font-heading); font-weight:700;">● @s</span>
            </div>
        }
    </div>
</div>
