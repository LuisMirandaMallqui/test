@page "/tienda/pedidos"
@layout MainLayout
@inject AuthService Auth
@inject PedidoService PedidoSvc

@*  Historial de pedidos del cliente — RF018 (con opción "repetir pedido"). *@

@code {
    private List<Pedido> _pedidos = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.UsuarioActual is null) return;
        _pedidos = await PedidoSvc.ListarPorClienteAsync(Auth.UsuarioActual.Id);
        _loading = false;
    }

    private string Color(EstadoPedido e) => e switch
    {
        EstadoPedido.Entregado  => "var(--color-green)",
        EstadoPedido.EnRuta     => "var(--color-amber)",
        EstadoPedido.Preparando => "var(--color-blue)",
        EstadoPedido.Anulado    => "var(--color-red)",
        _ => "var(--color-muted)",
    };
}

<AppHeader BadgeText="MIS PEDIDOS" BadgeColor="blue" />

<div style="flex:1; overflow-y:auto; padding:20px 28px; max-width:880px; margin:0 auto; width:100%;">

    <div style="font-family:var(--font-heading); font-weight:800; font-size:26px; margin-bottom:6px;">📋 Mis Pedidos</div>
    <div class="muted" style="font-size:13px; margin-bottom:20px;">RF018 — Historial con opción de repetir pedido</div>

    @if (_loading)
    {
        <div class="muted">Cargando...</div>
    }
    else if (_pedidos.Count == 0)
    {
        <div class="card" style="text-align:center; padding:40px;">
            <div style="font-size:42px;">📦</div>
            <div style="font-size:16px; margin-top:8px;">Aún no tienes pedidos</div>
        </div>
    }
    else
    {
        <div style="display:flex; flex-direction:column; gap:10px;">
            @foreach (var p in _pedidos)
            {
                <div class="card" style="padding:14px 18px;">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                        <div>
                            <div class="mono amber" style="font-weight:700; font-size:13px;">@p.Codigo</div>
                            <div class="muted" style="font-size:11px;">@p.Fecha.ToString("dd MMM yyyy · HH:mm")</div>
                        </div>
                        <span class="pill" style="background:@(Color(p.Estado))22; color:@Color(p.Estado);">@p.Estado</span>
                    </div>
                    <div style="display:flex; flex-direction:column; gap:3px; margin-bottom:10px;">
                        @foreach (var d in p.Detalles.Take(3))
                        {
                            <div style="font-size:12px; display:flex; justify-content:space-between;">
                                <span>@d.Cantidad × @d.ProductoNombre</span>
                                <span class="mono muted">S/@d.Subtotal.ToString("F2")</span>
                            </div>
                        }
                        @if (p.Detalles.Count > 3)
                        {
                            <div class="muted" style="font-size:11px;">+ @(p.Detalles.Count - 3) producto(s) más</div>
                        }
                    </div>
                    <div style="display:flex; justify-content:space-between; align-items:center;
                                padding-top:10px; border-top:1px solid var(--color-border);">
                        <span class="mono" style="font-size:14px;">Total: <span class="amber" style="font-weight:700;">S/@p.Total.ToString("F2")</span></span>
                        <button class="btn btn-ghost">🔄 Repetir pedido</button>
                    </div>
                </div>
            }
        </div>
    }
</div>
