@page "/tienda/carrito"
@layout MainLayout
@inject CarritoState Carrito
@inject PedidoService PedidoSvc
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

@*  Carrito y checkout — RF016 (gestión), RF017 (reserva 10 min), RF008 (pago). *@

@code {
    private bool _checkout;
    private bool _confirmado;
    private string _modalidad = "delivery";     // delivery | recojo
    private System.Threading.Timer? _tick;

    protected override void OnInitialized()
    {
        Carrito.OnCambio += Refrescar;
        _tick = new System.Threading.Timer(_ => InvokeAsync(StateHasChanged), null, 0, 1000);
    }

    public void Dispose()
    {
        Carrito.OnCambio -= Refrescar;
        _tick?.Dispose();
    }

    private void Refrescar() => InvokeAsync(StateHasChanged);

    private string TiempoRestanteTexto
    {
        get
        {
            var t = Carrito.TiempoRestante;
            if (t is null) return "";
            if (t.Value.TotalSeconds <= 0) return "00:00 — reserva expirada";
            return $"{t.Value.Minutes:D2}:{t.Value.Seconds:D2}";
        }
    }

    private async Task ConfirmarPago((MetodoPago metodo, decimal efectivo) data)
    {
        var pedido = new Pedido
        {
            Codigo    = $"WEB-{DateTime.Now:HHmmss}",
            Canal     = CanalVenta.Web,
            MetodoPago= data.metodo,
            Subtotal  = Carrito.Subtotal,
            Igv       = Carrito.Igv,
            Total     = Carrito.Total,
            Detalles  = Carrito.Items.Select(i => new DetallePedido {
                ProductoId = i.Producto.Id,
                ProductoNombre = i.Producto.Nombre,
                Cantidad = i.Cantidad,
                PrecioUnitario = i.Producto.Precio
            }).ToList(),
            ClienteId   = Auth.UsuarioActual?.Id ?? 0,
            ClienteNombre = Auth.UsuarioActual?.Nombre ?? "Invitado",
            DireccionEntrega = _modalidad == "delivery" ? Auth.UsuarioActual?.Direccion : null,
        };
        await PedidoSvc.ConfirmarPedidoWebAsync(pedido);
        Carrito.Vaciar();
        _checkout = false;
        _confirmado = true;
    }
}

<AppHeader BadgeText="CARRITO" BadgeColor="blue" />

<div style="flex:1; overflow-y:auto; padding:20px 28px; max-width:780px; margin:0 auto; width:100%;">

    <div style="font-family:var(--font-heading); font-weight:800; font-size:26px; margin-bottom:18px;">
        🛒 Tu carrito (@Carrito.ItemsCount productos)
    </div>

    <!-- Cronómetro RF017 -->
    @if (Carrito.TiempoRestante is { } t && t.TotalSeconds > 0)
    {
        <div style="background:rgba(245,161,0,.08); border:1px solid rgba(245,161,0,.25);
                    border-radius:12px; padding:12px 16px; margin-bottom:14px;
                    display:flex; align-items:center; gap:12px;">
            <span style="font-size:24px;">⏱️</span>
            <div style="flex:1;">
                <div style="font-family:var(--font-heading); font-weight:700; font-size:14px;">Stock reservado para ti</div>
                <div class="muted" style="font-size:11px;">RF017 — se libera automáticamente si no confirmas el pedido</div>
            </div>
            <div class="mono amber" style="font-weight:700; font-size:22px;">@TiempoRestanteTexto</div>
        </div>
    }

    @if (Carrito.Items.Count == 0)
    {
        <div class="card" style="text-align:center; padding:60px 20px;">
            <div style="font-size:48px;">🛒</div>
            <div style="font-family:var(--font-heading); font-weight:700; font-size:18px; margin:8px 0;">Tu carrito está vacío</div>
            <button class="btn btn-primary" @onclick="() => Nav.NavigateTo("/tienda")">Ir al catálogo →</button>
        </div>
    }
    else
    {
        <!-- Items -->
        <div class="card" style="padding:0; margin-bottom:14px; overflow:hidden;">
            @foreach (var i in Carrito.Items)
            {
                <div style="display:flex; align-items:center; gap:12px; padding:12px 16px;
                            border-bottom:1px solid var(--color-border);">
                    <div style="width:42px; height:42px; background:var(--color-navy3); border-radius:8px;
                                display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0;">📦</div>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:13px; font-weight:600;">@i.Producto.Nombre</div>
                        <div class="muted mono" style="font-size:11px;">S/@i.Producto.Precio.ToString("F2") c/u</div>
                    </div>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <button class="btn btn-ghost" style="padding:4px 9px;" @onclick="() => Carrito.Cambiar(i.Producto.Id, -1)">−</button>
                        <span class="mono" style="font-weight:700; min-width:24px; text-align:center;">@i.Cantidad</span>
                        <button class="btn btn-primary" style="padding:4px 9px;" @onclick="() => Carrito.Cambiar(i.Producto.Id, +1)">+</button>
                    </div>
                    <div class="mono amber" style="font-weight:700; min-width:64px; text-align:right;">
                        S/@((i.Producto.Precio * i.Cantidad).ToString("F2"))
                    </div>
                </div>
            }
        </div>

        <!-- Modalidad de entrega -->
        <div class="card" style="margin-bottom:14px;">
            <div style="font-family:var(--font-heading); font-weight:700; font-size:14px; margin-bottom:10px;">Modalidad de entrega</div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                @foreach (var op in new[] { ("recojo","🏪","Recojo en tienda","Listo en 15 min"),
                                            ("delivery","🛵","Delivery","30-45 min · desde S/10") })
                {
                    var sel = _modalidad == op.Item1;
                    <button class="btn" @onclick="() => _modalidad = op.Item1"
                            style="text-align:left; padding:12px 14px; border-radius:10px;
                                   background:@(sel ? "rgba(245,161,0,.08)" : "var(--color-navy3)");
                                   border:1.5px solid @(sel ? "var(--color-amber)" : "var(--color-border)");">
                        <div style="font-size:22px; margin-bottom:4px;">@op.Item2</div>
                        <div style="font-size:13px; font-weight:700;">@op.Item3</div>
                        <div class="muted" style="font-size:11px; font-weight:400;">@op.Item4</div>
                    </button>
                }
            </div>
        </div>

        <!-- Resumen -->
        <div class="card">
            <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--color-muted); margin-bottom:4px;">
                <span>Subtotal</span><span class="mono">S/@Carrito.Subtotal.ToString("F2")</span>
            </div>
            <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--color-muted); margin-bottom:10px;">
                <span>IGV (18%)</span><span class="mono">S/@Carrito.Igv.ToString("F2")</span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; padding-top:10px;
                        border-top:1px solid var(--color-border); margin-bottom:14px;">
                <span style="font-family:var(--font-heading); font-weight:700; font-size:18px;">TOTAL</span>
                <span class="mono amber" style="font-weight:700; font-size:24px;">S/@Carrito.Total.ToString("F2")</span>
            </div>
            <button class="btn btn-primary pulse" style="width:100%; padding:14px 0; font-size:17px;"
                    @onclick="() => _checkout = true">
                Proceder al pago →
            </button>
        </div>
    }
</div>

@if (_checkout)
{
    <PaymentModal Total="Carrito.Total"
                  OnConfirmar="ConfirmarPago"
                  OnCerrar="() => _checkout = false" />
}

@if (_confirmado)
{
    <div style="position:fixed; inset:0; background:rgba(6,12,20,.85);
                display:flex; align-items:center; justify-content:center; z-index:90;">
        <div class="card fade-up" style="width:440px; text-align:center; padding:32px;">
            <div style="font-size:54px;">🎉</div>
            <div style="font-family:var(--font-heading); font-weight:800; font-size:24px; color:var(--color-green);">¡PEDIDO CONFIRMADO!</div>
            <div class="muted" style="font-size:12px; margin:6px 0 18px;">
                @(_modalidad == "delivery" ? "Delivery en camino 🛵" : "Listo para recoger 🏪")
            </div>
            <button class="btn btn-primary" style="width:100%; padding:12px 0; font-size:15px;"
                    @onclick="() => Nav.NavigateTo("/tienda")">Seguir comprando</button>
        </div>
    </div>
}
