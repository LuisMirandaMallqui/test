@page "/tienda"
@layout MainLayout
@inject ProductoService ProdSvc
@inject CarritoState Carrito
@inject NavigationManager Nav

@*  Portal cliente — RF003 catálogo, RF015 sesión, RF016 carrito.            *@

@code {
    private List<Producto> _productos = new();
    private List<Producto> _trending  = new();
    private string  _cat = "Todos";
    private string  _q   = "";
    private bool    _loading = true;
    private string  _view = "home"; // home | catalog

    private readonly string[] _cats = { "Todos","Abarrotes","Bebidas","Lácteos","Limpieza","Snacks","Frutas","Panadería" };
    private string IconCat(string c) => c switch
    {
        "Abarrotes"=>"🥫", "Bebidas"=>"🥤", "Lácteos"=>"🥛", "Limpieza"=>"🧴",
        "Snacks"=>"🍿", "Frutas"=>"🥬", "Panadería"=>"🍞", _ => "🛒",
    };

    protected override async Task OnInitializedAsync()
    {
        _productos = await ProdSvc.ListarAsync();
        _trending  = _productos.OrderByDescending(p => p.Vendidos).Take(6).ToList();
        _loading = false;
    }

    private IEnumerable<Producto> Filtrados =>
        _productos.Where(p =>
            (_cat == "Todos" || p.CategoriaNombre == _cat) &&
            (string.IsNullOrWhiteSpace(_q) || p.Nombre.Contains(_q, StringComparison.OrdinalIgnoreCase)));

    private void IrCatalogo(string cat) { _cat = cat; _view = "catalog"; }
    private void AbrirCarrito() => Nav.NavigateTo("/tienda/carrito");
}

<AppHeader BadgeText="TIENDA" BadgeColor="blue" />

<!-- Barra de categorías -->
<div style="background:#1a2e48; border-bottom:2px solid var(--color-amber);
            padding:0 18px; display:flex; gap:0; overflow-x:auto;">
    @foreach (var c in _cats)
    {
        var act = _cat == c && _view == "catalog";
        <button class="btn" @onclick="() => IrCatalogo(c)"
                style="background:transparent; border:none;
                       border-bottom:3px solid @(act ? "var(--color-amber)" : "transparent");
                       color:@(act ? "var(--color-amber)" : "var(--color-muted)");
                       font-size:14px; padding:9px 14px; white-space:nowrap;">
            @IconCat(c) @c
        </button>
    }
    <button class="btn" @onclick="() => _view = "home""
            style="background:transparent; border:none;
                   border-bottom:3px solid @(_view=="home" ? "var(--color-amber)" : "transparent");
                   color:@(_view=="home" ? "var(--color-amber)" : "var(--color-muted)");
                   font-size:14px; padding:9px 14px;">🏠 Inicio</button>
</div>

<div style="flex:1; overflow-y:auto; padding:18px;">

    <!-- Búsqueda -->
    <div style="position:relative; margin-bottom:16px;">
        <span class="muted" style="position:absolute; left:12px; top:50%; transform:translateY(-50%);">🔍</span>
        <input class="inp" style="padding-left:34px;" placeholder="Buscar productos, marcas y más..."
               @bind="_q" @bind:event="oninput" @onfocusout="() => _view = "catalog"" />
    </div>

    @if (_view == "home" && string.IsNullOrWhiteSpace(_q))
    {
        <!-- Hero -->
        <div style="background:linear-gradient(120deg, var(--color-red), #9c1a10);
                    border-radius:16px; padding:22px 26px; margin-bottom:18px;
                    display:flex; align-items:center; justify-content:space-between; overflow:hidden;">
            <div>
                <Pill Variant="amber">🔥 OFERTA DEL DÍA</Pill>
                <div style="font-family:var(--font-heading); font-weight:900; font-size:30px; line-height:1.05; color:#fff; margin-top:8px;">
                    Hasta 30% OFF<br />en Bebidas y Lácteos
                </div>
                <button class="btn btn-primary" style="margin-top:12px;" @onclick="() => IrCatalogo("Bebidas")">Ver ofertas →</button>
            </div>
            <div style="font-size:72px;">🥤</div>
        </div>

        <!-- Más vendidos -->
        <div style="font-family:var(--font-heading); font-weight:800; font-size:18px; margin-bottom:12px;">🔥 Más Vendidos</div>
        <div style="display:flex; flex-direction:column; gap:6px;">
            @for (int i = 0; i < _trending.Count; i++)
            {
                var p = _trending[i];
                var rank = i + 1;
                <div class="card" style="display:flex; align-items:center; gap:12px; padding:10px 14px; cursor:pointer;"
                     @onclick="() => Carrito.Agregar(p)">
                    <div style="font-family:var(--font-heading); font-weight:900; font-size:20px;
                                color:@(rank<=3 ? "var(--color-amber)" : "var(--color-muted)"); min-width:28px;">#@rank</div>
                    <div style="font-size:22px;">@IconCat(p.CategoriaNombre)</div>
                    <div style="flex:1;">
                        <div style="font-size:13px; font-weight:600;">@p.Nombre</div>
                        <div class="muted" style="font-size:10px;">@p.Vendidos vendidos este mes</div>
                    </div>
                    <div class="mono amber" style="font-weight:700; font-size:15px;">S/@p.Precio.ToString("F2")</div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Catálogo -->
        <div style="font-family:var(--font-heading); font-weight:800; font-size:18px; margin-bottom:12px;">
            @(string.IsNullOrWhiteSpace(_q) ? _cat : $"Resultados para \"{_q}\"")
            <span class="muted" style="font-family:var(--font-body); font-weight:400; font-size:13px;">
                (@Filtrados.Count() productos)
            </span>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(170px, 1fr)); gap:12px;">
            @foreach (var p in Filtrados)
            {
                <ProductCard Producto="p" />
            }
        </div>
    }
</div>

<!-- FAB carrito -->
@if (Carrito.ItemsCount > 0)
{
    <button class="btn pulse" @onclick="AbrirCarrito"
            style="position:fixed; bottom:24px; right:24px; width:56px; height:56px; border-radius:50%;
                   background:var(--color-amber); color:var(--color-navy); font-size:22px;
                   box-shadow:0 4px 20px rgba(245,161,0,.4); z-index:50;">
        🛒
        <span style="position:absolute; top:-3px; right:-3px; background:var(--color-red); color:#fff;
                     border-radius:50%; width:20px; height:20px; font-size:10px; font-weight:700;
                     display:flex; align-items:center; justify-content:center;">@Carrito.ItemsCount</span>
    </button>
}

<style>
    .app-shell { background: radial-gradient(ellipse at top, #1a2e48, var(--color-navy) 55%); }
</style>
