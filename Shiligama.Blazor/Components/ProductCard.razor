@inject CarritoState Carrito

@code {
    [Parameter, EditorRequired] public Producto Producto { get; set; } = default!;
    [Parameter] public bool Flash { get; set; }
    [Parameter] public EventCallback<Producto> OnAgregar { get; set; }

    private bool _hover;

    private string IconCategoria => Producto.CategoriaNombre switch
    {
        "Abarrotes" => "🥫", "Bebidas" => "🥤", "Lácteos" => "🥛",
        "Limpieza" => "🧴", "Snacks" => "🍿", "Frutas" => "🥬",
        "Panadería" => "🍞", _ => "📦",
    };

    private async Task Agregar()
    {
        Carrito.Agregar(Producto);
        if (OnAgregar.HasDelegate) await OnAgregar.InvokeAsync(Producto);
    }
}

<div class="card prod-card @( _hover ? "hover" : "" )"
     @onmouseenter="() => _hover = true"
     @onmouseleave="() => _hover = false"
     style="padding:0; overflow:hidden; cursor:pointer;
            border-color:@(_hover ? "var(--color-amber)" : "var(--color-border)");
            transform:@(_hover ? "translateY(-3px)" : "none");
            box-shadow:@(_hover ? "0 8px 24px rgba(245,161,0,.12)" : "none");
            transition:all .2s;">

    <div style="position:relative; aspect-ratio:1; background:var(--color-navy3);
                display:flex; align-items:center; justify-content:center; font-size:52px;">
        @IconCategoria
        @if (Producto.Descuento > 0)
        {
            <div style="position:absolute; top:8px; left:8px; background:var(--color-red); color:#fff;
                        font-size:10px; font-weight:700; padding:3px 7px; border-radius:5px;">
                -@(Producto.Descuento)%
            </div>
        }
        @if (Producto.Stock <= 5)
        {
            <div style="position:absolute; top:8px; right:8px; background:rgba(224,51,34,.85); color:#fff;
                        font-size:9px; font-weight:700; padding:2px 6px; border-radius:5px;">ÚLTIMAS</div>
        }
    </div>

    <div style="padding:10px 12px;">
        <div style="font-size:11px; font-weight:600; line-height:1.3; margin-bottom:4px;">@Producto.Nombre</div>

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
            <div>
                <div class="mono amber" style="font-weight:700; font-size:15px;">S/@Producto.Precio.ToString("F2")</div>
                @if (Producto.PrecioOriginal.HasValue)
                {
                    <div class="mono muted" style="font-size:10px; text-decoration:line-through;">S/@Producto.PrecioOriginal.Value.ToString("F2")</div>
                }
            </div>
        </div>

        <button class="btn"
                style="width:100%; padding:8px 0; border-radius:8px;
                       background:@(_hover ? "var(--color-amber)" : "rgba(245,161,0,.12)");
                       color:@(_hover ? "var(--color-navy)" : "var(--color-amber)");
                       border:1px solid var(--color-amber); font-size:13px;"
                @onclick="Agregar">
            + Agregar al carrito
        </button>
    </div>
</div>
