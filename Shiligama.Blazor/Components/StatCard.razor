@code {
    [Parameter, EditorRequired] public string Icon  { get; set; } = "📊";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter]                 public string Sub   { get; set; } = "";
    [Parameter]                 public string Color { get; set; } = "var(--color-amber)";
}

<div class="card" style="padding:16px 18px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="font-size:24px; margin-bottom:6px;">@Icon</div>
        <div style="font-size:9px; font-family:var(--font-heading); font-weight:600;
                    color:var(--color-muted); letter-spacing:.5px; text-transform:uppercase; text-align:right;">@Label</div>
    </div>
    <div class="mono" style="font-weight:700; font-size:22px; color:@Color;">@Value</div>
    <div class="muted" style="font-size:11px; margin-top:2px;">@Sub</div>
</div>
