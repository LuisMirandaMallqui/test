@inject AuthService Auth
@inject NavigationManager Nav

@code {
    [Parameter] public string BadgeText { get; set; } = "";
    [Parameter] public string BadgeColor { get; set; } = "amber";

    private string _now = DateTime.Now.ToString("ddd dd MMM · HH:mm:ss");
    private System.Threading.Timer? _t;

    protected override void OnInitialized()
    {
        _t = new System.Threading.Timer(_ =>
        {
            _now = DateTime.Now.ToString("ddd dd MMM · HH:mm:ss");
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    public void Dispose() => _t?.Dispose();

    private void Salir()
    {
        Auth.CerrarSesion();
        Nav.NavigateTo("/login");
    }
}

<header class="app-header">
    <Logo Size="sm" />
    <div style="width:1px; height:22px; background:var(--color-border);"></div>
    @if (!string.IsNullOrEmpty(BadgeText))
    {
        <Pill Variant="@BadgeColor">@BadgeText</Pill>
    }
    <span class="muted" style="font-size:11px;">@_now</span>

    <div style="margin-left:auto; display:flex; align-items:center; gap:10px;">
        <span style="width:6px; height:6px; border-radius:50%; background:var(--color-green); box-shadow:0 0 6px var(--color-green);"></span>
        <span class="muted" style="font-size:12px;">@(Auth.UsuarioActual?.Nombre ?? "Invitado")</span>
        <button class="btn btn-ghost" @onclick="Salir">← Salir</button>
    </div>
</header>
